            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .element-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
