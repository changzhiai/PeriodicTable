            margin-top: 20px;
        }

        a.list-link {
            color: #2563eb;
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 6px;
            background: transparent;
            border: 1px solid #e2e8f0;
            display: inline-block;
            transition: all 0.2s;
            text-align: center;
        }

        a.list-link:hover {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
            transform: translateY(-2px);
        }

        .element-link {
